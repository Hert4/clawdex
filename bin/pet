#!/usr/bin/env bash
# clawdex pet wrapper — handles arg resolution then forwards to ctl.py.
#
# Usage:
#   pet                  → status
#   pet list             → list pets
#   pet boba             → switch to boba (unknown subcommand → treated as switch)
#   pet stop|start|...   → passed through unchanged
#
# When invoked via `! pet ...` in the Claude Code REPL the output lands
# directly in the conversation without round-trip reasoning.

set -e

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON="${CLAWDEX_PYTHON:-python3}"
CTL="${CLAWDEX_CTL:-$HERE/../src/ctl.py}"

if [ $# -eq 0 ]; then
  exec "$PYTHON" "$CTL" status
fi

case "$1" in
  start|stop|restart|switch|list|status|scale|state|hook)
    exec "$PYTHON" "$CTL" "$@"
    ;;
  *)
    # Unknown first arg → assume the user named a pet ("/pet boba" → switch boba).
    exec "$PYTHON" "$CTL" switch "$@"
    ;;
esac
